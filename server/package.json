{
  "name": "server",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run index.ts",
    "dev": "DATABASE_DIR=file:./prisma bun run  --watch ./ index.ts",
    "create-schema": "bunx --bun prisma init --datasource-provider sqlite --output ./db",
    "create-model": "bunx --bun prisma generate",
    "create-data": "bunx prisma migrate dev --name init"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "prisma": "^7.7.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@prisma/adapter-libsql": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "date-fns": "^4.1.0",
    "elysia": "^1.4.28",
    "lodash": "^4.18.1",
    "uuid": "^13.0.0"
  }
}